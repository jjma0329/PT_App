generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  goal      String?
  message   String?
  createdAt DateTime @default(now())
}

model OAuthToken {
  id           Int      @id @default(autoincrement())
  provider     String   @default("google")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}
