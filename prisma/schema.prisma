generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ContactSubmission {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  goal      String?
  message   String?
  createdAt DateTime @default(now())
}

model OAuthToken {
  id           Int      @id @default(autoincrement())
  provider     String   @default("google")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  updatedAt    DateTime @updatedAt
}

model Booking {
  id            Int      @id @default(autoincrement())
  name          String
  email         String
  phone         String?
  message       String?
  slotTime      DateTime @unique // @unique enforces DB-level double-booking protection
  status        String   @default("confirmed")
  googleEventId String?  // null if calendar event creation failed (non-fatal)
  createdAt     DateTime @default(now())
}
