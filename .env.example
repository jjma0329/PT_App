# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Server
PORT=3001
ALLOWED_ORIGIN="http://localhost:5173"    # Set to your frontend URL in production

# Session (generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log")
SESSION_SECRET="replace-with-a-long-random-string"

# Trainer admin login
ADMIN_EMAIL="trainer@example.com"
# Generate hash with: node -e "require('bcrypt').hash('yourpassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$12$..."

# JWT (generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log")
JWT_SECRET="replace-with-a-long-random-string"

# Email via Resend (https://resend.com)
RESEND_API="re_xxxxxxxxxxxx"
TRAINER_EMAIL="trainer@example.com"
# Override once you have a verified Resend domain — default uses Resend sandbox
RESEND_FROM_EMAIL="JJM Fitness <you@yourdomain.com>"

# Timezone for email timestamps (e.g. "Asia/Taipei", "America/New_York")
TRAINER_TIMEZONE="UTC"

# Google Calendar OAuth (from Google Cloud Console)
OAUTH_CLIENT="your-client-id.apps.googleusercontent.com"
OAUTH_SECRET="your-client-secret"
OAUTH_REDIRECT_URI="http://localhost:3001/auth/google/callback"
